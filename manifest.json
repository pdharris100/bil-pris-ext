  {
    "name": "Car Price Estimator",
    "version": "1.0",
    "description": "Car Price Estimator",
    "permissions": [
      "storage",
      "activeTab",
      "cookies",
      "https://www.bilbasen.dk/*"
    ],
    "browser_action": {
      "default_title": "Car Price Estimator",
      "default_icon": "launcher-icon-1x.png",
      "default_popup": "popup.html"
    },
    "content_scripts": [
      {
        "matches": ["https://www.bilbasen.dk/*"],
        "js": [
          "content.js"
        ],
        "run_at": "document_end"
      }
    ],
    "content_security_policy": "script-src 'self' https://cdnjs.cloudflare.com; object-src 'self'",
    "manifest_version": 2
}